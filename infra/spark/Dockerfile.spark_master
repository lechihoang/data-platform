FROM apache/spark:4.0.0

# Switch to root to install packages globally
USER root

# Install Python dependencies using standard pip
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy Spark config
COPY config/spark-defaults.conf /opt/spark/conf/spark-defaults.conf
COPY config/log4j2.properties /opt/spark/conf/log4j2.properties

# Pre-download all required Spark JARs into the image
RUN mkdir -p /opt/spark/baked-jars && \
    curl -sL -o /opt/spark/baked-jars/hadoop-aws-3.4.1.jar https://repo1.maven.org/maven2/org/apache/hadoop/hadoop-aws/3.4.1/hadoop-aws-3.4.1.jar && \
    curl -sL -o /opt/spark/baked-jars/iceberg-aws-bundle-1.11.0.jar https://repo1.maven.org/maven2/org/apache/iceberg/iceberg-aws-bundle/1.11.0/iceberg-aws-bundle-1.11.0.jar && \
    curl -sL -o /opt/spark/baked-jars/iceberg-spark-runtime-4.0_2.13-1.11.0.jar https://repo1.maven.org/maven2/org/apache/iceberg/iceberg-spark-runtime-4.0_2.13/1.11.0/iceberg-spark-runtime-4.0_2.13-1.11.0.jar && \
    curl -sL -o /opt/spark/baked-jars/nessie-spark-extensions-4.0_2.13-0.108.1.jar https://repo1.maven.org/maven2/org/projectnessie/nessie-integrations/nessie-spark-extensions-4.0_2.13/0.108.1/nessie-spark-extensions-4.0_2.13-0.108.1.jar && \
    curl -sL -o /opt/spark/baked-jars/bundle-2.24.6.jar https://repo1.maven.org/maven2/software/amazon/awssdk/bundle/2.24.6/bundle-2.24.6.jar && \
    curl -sL -o /opt/spark/baked-jars/wildfly-openssl-1.1.3.Final.jar https://repo1.maven.org/maven2/org/wildfly/openssl/wildfly-openssl/1.1.3.Final/wildfly-openssl-1.1.3.Final.jar && \
    curl -sL -o /opt/spark/baked-jars/openlineage-spark_2.13-1.51.0.jar https://repo1.maven.org/maven2/io/openlineage/openlineage-spark_2.13/1.51.0/openlineage-spark_2.13-1.51.0.jar && \
    chown -R 185:185 /opt/spark/baked-jars

RUN mkdir -p /opt/spark/custom-jars /opt/spark-events /opt/spark/work && \
    chown -R 185:185 /opt/spark/custom-jars /opt/spark-events /opt/spark/work
# Switch back to spark user
USER 185
